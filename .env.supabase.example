# =============================================================
# .env.supabase.example — modelo de credenciais Supabase
# NUNCA commitar o .env.supabase real (está no .gitignore)
# Copiar para .env.supabase e preencher com valores reais
# =============================================================

# Obtido em: app.supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Obtido em: app.supabase.com → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# Obtido em: Project Settings → API → service_role key
# Usar APENAS para migrations e scripts admin — nunca expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# URL do projeto (Project Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Senha do banco (Project Settings → Database → Database password)
SUPABASE_DB_PASSWORD=xxxxxxxxxxxxxxxxxxxx
